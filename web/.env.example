# Copy to .env.local for local development.
# Get values from Supabase: Project Settings → API.

# Public client vars (safe to expose in the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# If unset or invalid, middleware skips Supabase auth (useful for offline UI work).

# Sentry error monitoring (get DSN from Sentry project settings → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123.ingest.us.sentry.io/456
SENTRY_DSN=https://your-dsn@o123.ingest.us.sentry.io/456
